# Supabase — Settings > API in your project dashboard
# Anon key: new format starts with sb_publishable_  (legacy eyJ… JWTs also accepted)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key: new format starts with sb_secret_  (legacy eyJ… JWTs also accepted)
# Never expose this key client-side. Used by cron routes and all Kid-Mode writes.
SUPABASE_SERVICE_ROLE_KEY=

# Child (Kid Mode) session signing secret — generate with: openssl rand -hex 32
# Must be at least 32 random characters. Never expose client-side.
CHILD_SESSION_SECRET=

# Cron secret — protects the rota / fallback / pocket-money cron routes.
# Generate with: openssl rand -hex 32. Set as a Vercel env var; Vercel cron
# sends it automatically as the Authorization: Bearer header.
CRON_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000
